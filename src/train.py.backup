#!/usr/bin/env python3
"""
PAPER-GRADE+ SEPSIS TRAINING PIPELINE
"""

import argparse
import csv
import json
import sys
import time
from pathlib import Path
from collections import defaultdict
import numpy as np

import torch
import torch.nn as nn
from torch.utils.data import DataLoader
from tqdm import tqdm
from sklearn.metrics import roc_auc_score, f1_score, accuracy_score, roc_curve

sys.path.insert(0, str(Path(__file__).parent))
from models import create_model, count_parameters

# -----------------------------
# SCHEDULER
# -----------------------------
class WarmupCosine:
    def __init__(self, optimizer, warmup_steps, total_steps, min_lr=1e-6):
        self.optimizer = optimizer
        self.warmup_steps = warmup_steps
        self.total_steps = total_steps
        self.min_lr = min_lr
        self.base_lrs = [g['lr'] for g in optimizer.param_groups]
        self.step_num = 0

    def step(self):
        self.step_num += 1
        for i, pg in enumerate(self.optimizer.param_groups):
            base_lr = self.base_lrs[i]
            if self.step_num < self.warmup_steps:
                lr = base_lr * self.step_num / max(1, self.warmup_steps)
            else:
                p = (self.step_num - self.warmup_steps) / max(1, self.total_steps - self.warmup_steps)
                lr = self.min_lr + (base_lr - self.min_lr) * 0.5 * (1 + np.cos(np.pi * p))
            pg['lr'] = lr

# -----------------------------
# THRESHOLD OPT
# -----------------------------
def find_best_threshold(y_true, y_prob):
    best_t, best_f1 = 0.5, 0
    for t in np.linspace(0.05, 0.95, 50):
        f1 = f1_score(y_true, (y_prob > t).astype(int), zero_division=0)
        if f1 > best_f1:
            best_f1, best_t = f1, t
    return best_t, best_f1

# -----------------------------
# TRAIN
# -----------------------------
def train_epoch(model, loader, criterion, optimizer, scaler, scheduler, device):
    model.train()
    preds, labels = [], []
    total_loss = 0

    for x, mask, y in tqdm(loader, desc="train", leave=False):
        x, mask, y = x.to(device), mask.to(device), y.to(device)
        optimizer.zero_grad(set_to_none=True)

        with torch.cuda.amp.autocast(device.type == 'cuda'):
            out = model(x, mask)
            loss = criterion(out, y)

        if torch.isnan(loss):
            continue

        scaler.scale(loss).backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
        scaler.step(optimizer)
        scaler.update()
        scheduler.step()

        total_loss += loss.item()
        p = torch.sigmoid(out).detach().cpu().numpy()
        preds.extend(p)
        labels.extend(y.cpu().numpy())

    return total_loss / max(1, len(loader)), np.array(preds), np.array(labels)

# -----------------------------
# EVAL
# -----------------------------
@torch.no_grad()
def evaluate(model, loader, criterion, device):
    model.eval()
    loss_sum, preds, labels = 0, [], []

    for x, mask, y in loader:
        x, mask, y = x.to(device), mask.to(device), y.to(device)
        with torch.cuda.amp.autocast(device.type == 'cuda'):
            logits = model(x, mask)
            loss = criterion(logits, y)
            loss_sum += loss.item()
            out = torch.sigmoid(logits)
        preds.extend(out.cpu().numpy())
        labels.extend(y.cpu().numpy())

    preds, labels = np.array(preds), np.array(labels)
    if len(np.unique(labels)) < 2:
        return loss_sum / max(1, len(loader)), 0.5, 0.0, 0.5, preds, labels

    return (
        loss_sum / len(loader),
        roc_auc_score(labels, preds),
        f1_score(labels, (preds > 0.5).astype(int), zero_division=0),
        accuracy_score(labels, (preds > 0.5).astype(int)),
        preds, labels
    )

# -----------------------------
# SAVE UTILS
# -----------------------------
def save_roc(y, p, path):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    if len(np.unique(y)) < 2:
        return
    fpr, tpr, thr = roc_curve(y, p)
    with open(path, "w") as f:
        w = csv.writer(f)
        w.writerow(["fpr", "tpr", "thr"])
        for a, b, c in zip(fpr, tpr, thr):
            w.writerow([a, b, c])

def save_metrics(metrics, path):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w") as f:
        json.dump(metrics, f, indent=2)

# -----------------------------
# MAIN
# -----------------------------
def main():
    ap = argparse.ArgumentParser()
    ap.add_argument('--model', required=True)
    ap.add_argument('--data-dir', type=str, default='../data/training_setA')
    ap.add_argument('--epochs', type=int, default=50)
    ap.add_argument('--batch-size', type=int, default=32)
    ap.add_argument('--lr', type=float, default=3e-4)
    ap.add_argument('--seq-len', type=int, default=48)
    ap.add_argument('--seed', type=int, default=42)
    ap.add_argument('--dummy', action='store_true')
    ap.add_argument('--save-dir', type=str, default='../models')
    ap.add_argument('--log-dir', type=str, default='../logs')
    ap.add_argument('--patience', type=int, default=5)
    ap.add_argument('--pos-weight', type=float, default=None)
    args = ap.parse_args()

    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
    print(f"Device: {device}")
    
    torch.manual_seed(args.seed)
    np.random.seed(args.seed)

    Path(args.save_dir).mkdir(parents=True, exist_ok=True)
    Path(args.log_dir).mkdir(parents=True, exist_ok=True)

    # MODEL - без d_model чтобы совместимо
    model = create_model(args.model, input_size=40).to(device)
    print(f"Parameters: {count_parameters(model):,}")

    # DATA
    if args.dummy:
        from dataset import SyntheticSepsisBatch
        train = SyntheticSepsisBatch(512, args.seq_len, 40)
        val = SyntheticSepsisBatch(128, args.seq_len, 40)
        train_loader = DataLoader(train, batch_size=args.batch_size, shuffle=True)
        val_loader = DataLoader(val, batch_size=args.batch_size)
    else:
        from dataset import create_dataloaders
        train_loader, val_loader = create_dataloaders(args.data_dir, args.seq_len, args.batch_size)

    # POS WEIGHT
    if args.pos_weight is not None:
        pos_weight = torch.tensor([args.pos_weight], device=device)
    else:
        all_y = []
        for _, _, y in train_loader:
            all_y.extend(y.numpy())
        pos = np.mean(all_y)
        pos_weight = torch.tensor([(1 - pos) / max(pos, 1e-6)], device=device)
    
    print(f"Positive weight: {pos_weight.item():.2f}")
    criterion = nn.BCEWithLogitsLoss(pos_weight=pos_weight)

    optimizer = torch.optim.AdamW(model.parameters(), lr=args.lr, weight_decay=1e-4)
    total_steps = args.epochs * len(train_loader)
    scheduler = WarmupCosine(optimizer, args.warmup if hasattr(args, 'warmup') else 500, total_steps)
    scaler = torch.cuda.amp.GradScaler(enabled=device.type=='cuda')

    best_auc, best_model_state, no_improve = 0, None, 0
    history = {'train_loss': [], 'val_loss': [], 'val_auc': [], 'val_f1': []}

    print(f"\n🚀 Starting training: {args.epochs} epochs, {len(train_loader)} batches/epoch")
    print("=" * 70)

    for epoch in range(args.epochs):
        t0 = time.time()
        tr_loss, tr_p, tr_y = train_epoch(model, train_loader, criterion, optimizer, scaler, scheduler, device)
        va_loss, auc, f1, acc, vp, vy = evaluate(model, val_loader, criterion, device)
        dt = time.time() - t0
        
        history['train_loss'].append(float(tr_loss))
        history['val_loss'].append(float(va_loss))
        history['val_auc'].append(float(auc))
        history['val_f1'].append(float(f1))
        
        print(f"Epoch {epoch+1:3d}/{args.epochs} | loss={tr_loss:.4f} | val_auc={auc:.4f} | val_f1={f1:.4f} | time={dt:.1f}s")
        
        if auc > best_auc:
            best_auc = auc
            best_model_state = model.state_dict().copy()
            no_improve = 0
            torch.save({
                'epoch': epoch,
                'model_state_dict': best_model_state,
                'val_auc': auc,
                'args': vars(args)
            }, Path(args.save_dir) / f"{args.model}_best.pt")
            print(f"  ✅ New best! Saved")
        else:
            no_improve += 1
            if no_improve >= args.patience:
                print(f"\n⚠️ Early stopping at epoch {epoch+1}")
                break

    print("=" * 70)
    print(f"🏆 Best AUROC: {best_auc:.4f}")
    
    if best_model_state:
        model.load_state_dict(best_model_state)
    
    # Final eval
    _, _, _, _, vp, vy = evaluate(model, val_loader, criterion, device)
    
    # Simple threshold (без калибровки чтобы избежать багов)
    best_t, best_f1 = find_best_threshold(vy, vp)
    print(f"📊 Threshold: {best_t:.3f} | F1: {best_f1:.4f}")
    
    # Save outputs
    save_roc(vy, vp, Path(args.log_dir) / f"{args.model}_roc.csv")
    
    metrics = {
        'model': args.model,
        'best_auc': float(best_auc),
        'best_threshold': float(best_t),
        'best_f1': float(best_f1),
        'epochs_trained': epoch + 1,
        'history': history
    }
    save_metrics(metrics, Path(args.log_dir) / f"{args.model}_metrics.json")
    
    # Training plot
    try:
        import matplotlib.pyplot as plt
        fig, axes = plt.subplots(1, 2, figsize=(14, 5))
        axes[0].plot(history['train_loss'], label='Train')
        axes[0].plot(history['val_loss'], label='Val')
        axes[0].set_xlabel('Epoch')
        axes[0].set_ylabel('Loss')
        axes[0].legend()
        axes[0].grid(alpha=0.3)
        axes[1].plot(history['val_auc'], label='AUROC', color='green')
        axes[1].plot(history['val_f1'], label='F1', color='orange')
        axes[1].set_xlabel('Epoch')
        axes[1].set_ylabel('Score')
        axes[1].legend()
        axes[1].grid(alpha=0.3)
        plt.tight_layout()
        plt.savefig(Path(args.log_dir) / f"{args.model}_training.png", dpi=300, bbox_inches='tight')
        plt.close()
        print(f"✅ Plot saved: {args.log_dir}/{args.model}_training.png")
    except Exception as e:
        print(f"⚠️ Plot error: {e}")
    
    print("\n🎉 TRAINING COMPLETE!")

if __name__ == "__main__":
    main()
